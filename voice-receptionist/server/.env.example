# ═══════════════════════════════════════════════
#  KI-Telefonempfang – Umgebungsvariablen
# ═══════════════════════════════════════════════

# ── Twilio (Telefonie) ────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+49XXXXXXXXXX

# ── Anthropic Claude (KI-Gehirn) ─────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ElevenLabs (Feminine Stimme / TTS) ────────
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Deutsche feminine Stimme – empfohlen: Charlotte, Lena oder Sarah
# Verfügbare IDs: https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Modell: eleven_multilingual_v2 für Deutsch (beste Qualität)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Server ────────────────────────────────────
PORT=3000
# Öffentliche URL (für Twilio-Webhooks) – z.B. ngrok oder dein Hosting
BASE_URL=https://dein-server.beispiel.de

# ── Unternehmen ───────────────────────────────
BUSINESS_NAME=Mein Unternehmen
# Typen: friseur | arzt | restaurant | anwalt | physiotherapie |
#         kosmetik | nagelstudio | zahnarzt | fitness | werkstatt | allgemein
BUSINESS_TYPE=allgemein
BUSINESS_PHONE=+49XXXXXXXXXX
BUSINESS_EMAIL=info@beispiel.de
BUSINESS_ADDRESS=Musterstraße 1, 12345 Musterstadt

# ── Sicherheit ────────────────────────────────
# Zufälliger Geheimschlüssel für die Dashboard-API
ADMIN_SECRET=aendere_dies_zu_einem_sicheren_geheimnis

# ── Optionen ──────────────────────────────────
# Sprache der KI-Antworten: de | en | fr | es | it
LANGUAGE=de
# Maximale Gesprächslänge in Minuten (0 = unbegrenzt)
MAX_CALL_DURATION=10
# Anzahl freier Termine in nächsten X Tagen anzeigen
AVAILABILITY_DAYS=14
